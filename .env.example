# MegaForm environment example.
# Copy this file to .env for local development and adjust values as needed.

# Authentication mode: local (single-user) or oauth (multi-user).
MEGAFORM_AUTH_MODE=local

# Enable email/password registration and login.
MEGAFORM_EMAIL_AUTH=true

# Keep this stable in production. Generate one with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MEGAFORM_SECRET_KEY=

# Required when OAuth/cookies need an externally reachable base URL.
MEGAFORM_PUBLIC_BASE_URL=http://localhost:8080

# Set to true when serving over HTTPS.
MEGAFORM_COOKIE_SECURE=false

# Google OAuth. Leave empty when unused.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

# Optional summary scheduling knobs.
MEGAFORM_ROOT_SUMMARY_DEBOUNCE_SECONDS=3600
MEGAFORM_ROOT_SUMMARY_DAILY_HOUR=3
